<!DOCTYPE html>
<html lang="mg">
<head>
<meta charset="UTF-8">
<title>Site-ko modern</title>

<style>
/* ===== RESET ===== */
* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
    font-family: Arial;
}

/* ===== BACKGROUND ANIMATION ===== */
body {
    height: 100vh;
    background: linear-gradient(-45deg, #4facfe, #00f2fe, #43e97b, #38f9d7);
    background-size: 400% 400%;
    animation: backgroundMove 10s ease infinite;
}

/* animation background */
@keyframes backgroundMove {
    0% {background-position: 0% 50%;}
    50% {background-position: 100% 50%;}
    100% {background-position: 0% 50%;}
}

/* ===== MENU ===== */
nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
    background: rgba(0,0,0,0.6);
    padding: 15px 30px;
    position: fixed;
    width: 100%;
    top: 0;
}

nav h1 {
    color: white;
}

nav ul {
    list-style: none;
    display: flex;
}

nav ul li {
    margin-left: 20px;
}

nav ul li a {
    color: white;
    text-decoration: none;
    transition: 0.3s;
}

nav ul li a:hover {
    color: yellow;
}

/* ===== CONTENT ===== */
.container {
    text-align: center;
    margin-top: 150px;
    color: white;
}

/* ===== BUTTON ANIMATION ===== */
button {
    padding: 12px 25px;
    border: none;
    border-radius: 8px;
    background: white;
    color: black;
    cursor: pointer;
    margin-top: 20px;
    transition: 0.3s;
}

button:hover {
    transform: scale(1.1);
    background: yellow;
}

/* ===== FADE IN TEXT ===== */
h2 {
    animation: fadeIn 2s ease-in-out;
}

@keyframes fadeIn {
    from {opacity: 0; transform: translateY(-20px);}
    to {opacity: 1; transform: translateY(0);}
}

</style>
</head>

<body>

<!-- MENU -->
<nav>
    <h1>MySite</h1>
    <ul>
        <li><a href="#">Home</a></li>
        <li><a href="#">About</a></li>
        <li><a href="#">Service</a></li>
        <li><a href="#">Contact</a></li>
    </ul>
</nav>

<!-- CONTENT -->
<div class="container">
    <h2>Salama 👋 Tonga soa!</h2>
    <p>Ity no site web modern voalohany nataonao</p>

    <button onclick="alert('Miasa tsara ilay site 🚀')">
        Tsindrio aho
    </button>
</div>

</body>
</html>
